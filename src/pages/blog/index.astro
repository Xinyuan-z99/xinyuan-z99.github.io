---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';

const posts = (
  await getCollection('blog', ({ data }) => data.draft !== true)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const groupedPosts = posts.reduce((acc, post) => {
  const cat = post.data.category;
  if (!cat) return acc;

  if (!acc[cat]) acc[cat] = [];
  acc[cat].push(post);
  return acc;
}, {});

const CATEGORY_ORDER = ['Network', 'Work Log', 'Life'];

const sortedCategories = Object.keys(groupedPosts).sort((a, b) => {
  const ia = CATEGORY_ORDER.indexOf(a);
  const ib = CATEGORY_ORDER.indexOf(b);
  const ra = ia === -1 ? 999 : ia;
  const rb = ib === -1 ? 999 : ib;
  return ra - rb || a.localeCompare(b);
});
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI',
          sans-serif;
        background: linear-gradient(180deg, #fbfaff 0%, #fdfcff 55%, #ffffff 100%);
        background-attachment: fixed;
      }

      main {
        width: 960px;
        max-width: calc(100% - 2em);
        margin: 3rem auto 4rem;
        padding: 0 1.5rem;
      }

      .page-title {
        margin: 0 0 0.5rem;
        font-size: 2.2rem;
      }

      .page-subtitle {
        margin: 0 0 2rem;
        color: rgb(var(--gray));
      }

      .filter-bar {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin: 0 0 2rem;
      }

      .filter-btn {
        border: 1px solid rgba(0, 0, 0, 0.08);
        background: rgba(255, 255, 255, 0.82);
        color: rgb(var(--gray-dark));
        padding: 0.55rem 1rem;
        border-radius: 999px;
        font-size: 0.95rem;
        cursor: pointer;
        transition: 0.2s ease;
      }

      .filter-btn:hover,
      .filter-btn.active {
        background: #eaf4ff;
        color: #3e88d8;
        border-color: rgba(90, 162, 230, 0.35);
      }

      .category-block {
        border-top: 1px solid rgba(0, 0, 0, 0.12);
        padding-top: 1.2rem;
        margin-top: 1.2rem;
      }

      .category-title {
        margin: 0 0 1rem;
        font-size: 1.4rem;
        color: rgb(var(--black));
      }

      ul {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
        list-style-type: none;
        margin: 0;
        padding: 0;
      }

      ul li {
        width: 100%;
      }

      ul li * {
        text-decoration: none;
        transition: 0.2s ease;
      }

      ul li a {
        display: block;
      }

      .title {
        margin: 0;
        color: rgb(var(--black));
        line-height: 1.2;
        font-size: 1.15rem;
        font-weight: 500;
      }

      ul li a:hover .title {
        color: rgb(var(--accent));
      }

      .hidden-category {
        display: none;
      }

      @media (max-width: 720px) {
        main {
          margin: 2rem auto 3rem;
        }

        .filter-bar {
          gap: 0.6rem;
        }

        .filter-btn {
          font-size: 0.9rem;
          padding: 0.5rem 0.85rem;
        }

        ul {
          gap: 1rem;
        }

        ul li {
          width: 100%;
          text-align: left;
        }
      }
    </style>
  </head>

  <body>
    <Header />
    <main>
      <section>
        <h1 class="page-title">📝 Blog · Notes & Growth</h1>
        <p class="page-subtitle">
          Notes and thoughts about networking, Japanese, and life in Japan.
        </p>

        <div class="filter-bar">
          <button class="filter-btn active" data-filter="all">All</button>
          <button class="filter-btn" data-filter="Work Log">Work Log</button>
          <button class="filter-btn" data-filter="Network">Network</button>
          <button class="filter-btn" data-filter="Life">Life</button>
        </div>
      </section>

      <section>
        {
          sortedCategories.map((cat) => (
            <div class="category-block" data-category={cat}>
              <h2 class="category-title">📂 {cat}</h2>
              <ul>
                {
                  groupedPosts[cat].map((post) => (
                    <li>
                      <a href={`/blog/${post.id}/`}>
                        <h4 class="title">{post.data.title}</h4>
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>
          ))
        }
      </section>
    </main>

    <Footer />

    <script>
      const buttons = document.querySelectorAll('.filter-btn');
      const blocks = document.querySelectorAll('.category-block');

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          const filter = button.dataset.filter;

          buttons.forEach((btn) => btn.classList.remove('active'));
          button.classList.add('active');

          blocks.forEach((block) => {
            const category = block.dataset.category;
            if (filter === 'all' || category === filter) {
              block.classList.remove('hidden-category');
            } else {
              block.classList.add('hidden-category');
            }
          });
        });
      });
    </script>
  </body>
</html>