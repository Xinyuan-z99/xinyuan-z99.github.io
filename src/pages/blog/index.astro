---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';

const posts = (
  await getCollection('blog', ({ data }) => data.draft !== true)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const groupedPosts = posts.reduce((acc, post) => {
  const cat = post.data.category;
  if (!cat) return acc;

  if (!acc[cat]) acc[cat] = [];
  acc[cat].push(post);
  return acc;
}, {});

const CATEGORY_ORDER = ['Network', 'Work Log', 'Life'];

const sortedCategories = Object.keys(groupedPosts).sort((a, b) => {
  const ia = CATEGORY_ORDER.indexOf(a);
  const ib = CATEGORY_ORDER.indexOf(b);
  const ra = ia === -1 ? 999 : ia;
  const rb = ib === -1 ? 999 : ib;
  return ra - rb || a.localeCompare(b);
});
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      :root {
        --bg: #fcf7fa;
        --bg-2: #fdf9fb;
        --card: rgba(255, 255, 255, 0.72);
        --card-soft: rgba(250, 243, 247, 0.92);
        --border: rgba(232, 206, 218, 0.72);
        --text: #8c7881;
        --heading: #7c626d;
        --soft-heading: #b596a3;
        --accent: #c998ab;
        --accent-deep: #b78497;
        --shadow: 0 10px 30px rgba(214, 191, 202, 0.14);
      }

      html,
      body {
        margin: 0;
        padding: 0;
        min-height: 100vh;
        background: linear-gradient(180deg, var(--bg-2) 0%, var(--bg) 60%, #ffffff 100%);
        background-attachment: fixed;
        color: var(--text);
        font-family: "Times New Roman", Georgia, serif;
      }

      main {
        width: min(980px, calc(100% - 2rem));
        margin: 2.4rem auto 4rem;
        padding: 0 1rem;
      }

      .hero {
        margin-bottom: 2rem;
        padding: 2rem 2rem 1.6rem;
        border: 1px solid var(--border);
        border-radius: 34px;
        background: var(--card);
        box-shadow: var(--shadow);
      }

      .page-title {
        margin: 0 0 0.5rem;
        font-size: clamp(2rem, 5vw, 3rem);
        line-height: 1.1;
        letter-spacing: 0.02em;
        color: var(--heading);
        font-weight: 700;
        font-family: "Times New Roman", Georgia, serif;
      }

      .page-subtitle {
        margin: 0;
        font-size: 1rem;
        line-height: 1.9;
        color: var(--soft-heading);
        font-family: "Times New Roman", Georgia, serif;
      }

      .filter-bar {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin: 1.6rem 0 0;
      }

      .filter-btn {
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.85);
        color: var(--text);
        padding: 0.58rem 1rem;
        border-radius: 999px;
        font-size: 0.95rem;
        font-family: "Times New Roman", Georgia, serif;
        cursor: pointer;
        transition:
          background 0.22s ease,
          color 0.22s ease,
          border-color 0.22s ease,
          transform 0.22s ease;
      }

      .filter-btn:hover {
        background: #f8edf2;
        color: var(--accent-deep);
        border-color: rgba(201, 152, 171, 0.45);
        transform: translateY(-1px);
      }

      .filter-btn.active {
        background: #f6e9ef;
        color: var(--accent-deep);
        border-color: rgba(201, 152, 171, 0.52);
      }

      .category-block {
        margin-top: 1.4rem;
        padding: 1.5rem 1.4rem 1.2rem;
        border: 1px solid var(--border);
        border-radius: 28px;
        background: var(--card-soft);
        box-shadow: 0 6px 20px rgba(214, 191, 202, 0.08);
      }

      .category-title {
        margin: 0 0 1rem;
        font-size: 1.35rem;
        color: var(--heading);
        font-weight: 700;
        letter-spacing: 0.02em;
        font-family: "Times New Roman", Georgia, serif;
      }

      ul {
        display: flex;
        flex-direction: column;
        gap: 0.9rem;
        list-style: none;
        margin: 0;
        padding: 0;
      }

      ul li {
        width: 100%;
      }

      ul li a {
        display: block;
        text-decoration: none;
        padding: 0.95rem 1rem;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.68);
        border: 1px solid rgba(232, 206, 218, 0.45);
        transition:
          transform 0.22s ease,
          background 0.22s ease,
          border-color 0.22s ease,
          box-shadow 0.22s ease;
      }

      ul li a:hover {
        transform: translateY(-2px);
        background: rgba(255, 255, 255, 0.92);
        border-color: rgba(201, 152, 171, 0.42);
        box-shadow: 0 8px 20px rgba(214, 191, 202, 0.12);
      }

      .title {
        margin: 0;
        color: var(--heading);
        line-height: 1.45;
        font-size: 1.08rem;
        font-weight: 600;
        letter-spacing: 0.01em;
        font-family: "Times New Roman", Georgia, serif;
      }

      ul li a:hover .title {
        color: var(--accent-deep);
      }

      .hidden-category {
        display: none;
      }

      @media (max-width: 720px) {
        main {
          margin: 1.8rem auto 3rem;
          padding: 0 0.8rem;
        }

        .hero {
          padding: 1.5rem 1.2rem 1.3rem;
          border-radius: 24px;
        }

        .page-title {
          font-size: clamp(1.8rem, 8vw, 2.4rem);
        }

        .page-subtitle {
          font-size: 0.96rem;
        }

        .filter-bar {
          gap: 0.6rem;
        }

        .filter-btn {
          font-size: 0.9rem;
          padding: 0.5rem 0.82rem;
        }

        .category-block {
          padding: 1.2rem 1rem 1rem;
          border-radius: 22px;
        }

        ul li a {
          padding: 0.85rem 0.9rem;
        }

        .title {
          font-size: 1rem;
        }
      }
    </style>
  </head>

  <body>
    <Header />

    <main>
      <section class="hero">
        <h1 class="page-title">📝 Blog · Notes & Growth</h1>
        <p class="page-subtitle">
          Notes and thoughts about networking, Japanese, and life in Japan.
        </p>

        <div class="filter-bar">
          <button class="filter-btn active" data-filter="all">All</button>
          <button class="filter-btn" data-filter="Work Log">Work Log</button>
          <button class="filter-btn" data-filter="Network">Network</button>
          <button class="filter-btn" data-filter="Life">Life</button>
        </div>
      </section>

      <section>
        {
          sortedCategories.map((cat) => (
            <div class="category-block" data-category={cat}>
              <h2 class="category-title">📂 {cat}</h2>
              <ul>
                {
                  groupedPosts[cat].map((post) => (
                    <li>
                      <a href={`/blog/${post.id}/`}>
                        <h4 class="title">{post.data.title}</h4>
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>
          ))
        }
      </section>
    </main>

    <Footer />

    <script>
      const buttons = document.querySelectorAll('.filter-btn');
      const blocks = document.querySelectorAll('.category-block');

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          const filter = button.dataset.filter;

          buttons.forEach((btn) => btn.classList.remove('active'));
          button.classList.add('active');

          blocks.forEach((block) => {
            const category = block.dataset.category;
            if (filter === 'all' || category === filter) {
              block.classList.remove('hidden-category');
            } else {
              block.classList.add('hidden-category');
            }
          });
        });
      });
    </script>
  </body>
</html>