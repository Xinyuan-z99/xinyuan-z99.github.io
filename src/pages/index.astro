---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const moments = [
  {
    image: '/images/moments/birthday.jpg',
    title: 'HAPPY BIRTHDAY',
    date: '2026.03',
    description: 'A New Chapter.',
  },
  {
    image: '/images/moments/takao.jpg',
    title: 'Takaozan',
    date: '2026.02',
    description: 'A quiet winter walk.',
  },
  {
    image: '/images/moments/cafe.jpg',
    title: 'Cafe Time',
    date: '2026.01',
    description: 'Small moments, soft memories.',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      :root {
        --bg1: #fff8fb;
        --bg2: #fdeff5;
        --card: rgba(255, 255, 255, 0.72);
        --border: rgba(255, 182, 193, 0.28);
        --text: #5b4b52;
        --title: #9f6f7d;
        --accent: #e9b7c5;
        --accent-dark: #d997ac;
        --shadow: 0 10px 30px rgba(222, 170, 190, 0.16);
      }

      body {
        margin: 0;
        font-family: 'Times New Roman', serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(255, 255, 255, 0.95), transparent 35%),
          linear-gradient(135deg, var(--bg1), var(--bg2));
      }

      .page-shell {
        min-height: 100vh;
      }

      .main {
        width: min(1100px, 92%);
        margin: 0 auto;
        padding: 2rem 0 4rem;
      }

      .hero-card,
      .about-card,
      .moments-card {
        background: var(--card);
        backdrop-filter: blur(10px);
        border: 1px solid var(--border);
        border-radius: 28px;
        box-shadow: var(--shadow);
      }

      .hero-card {
        padding: 3rem 2rem;
        text-align: center;
        margin-top: 1.5rem;
      }

      .hero-title {
        margin: 0;
        font-size: clamp(2.4rem, 5vw, 4.4rem);
        letter-spacing: 0.18em;
        color: var(--title);
        font-weight: 600;
      }

      .hero-subtitle {
        margin-top: 1rem;
        font-size: 1rem;
        letter-spacing: 0.08em;
        color: #8b6f79;
        line-height: 1.8;
      }

      .section-title {
        text-align: center;
        font-size: 1.6rem;
        letter-spacing: 0.18em;
        color: var(--title);
        margin: 0 0 1.5rem 0;
      }

      .about-card {
        margin-top: 2rem;
        padding: 2rem;
      }

      .about-text {
        max-width: 720px;
        margin: 0 auto;
        text-align: center;
        font-size: 1.03rem;
        line-height: 2;
        color: var(--text);
      }

      .about-text p {
        margin: 0 0 1rem 0;
      }

      .about-link-wrap {
        text-align: center;
        margin-top: 1.5rem;
      }

      .about-link {
        display: inline-block;
        padding: 0.7rem 1.4rem;
        border-radius: 999px;
        text-decoration: none;
        color: white;
        background: linear-gradient(135deg, var(--accent), var(--accent-dark));
        font-size: 0.95rem;
        letter-spacing: 0.08em;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        box-shadow: 0 8px 18px rgba(217, 151, 172, 0.22);
      }

      .about-link:hover {
        transform: translateY(-2px);
      }

      .moments-card {
        margin-top: 2rem;
        padding: 2rem;
      }

      .moments-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.4rem;
      }

      .moment-item {
        background: rgba(255, 255, 255, 0.65);
        border: 1px solid rgba(255, 192, 203, 0.2);
        border-radius: 22px;
        overflow: hidden;
        box-shadow: 0 8px 20px rgba(223, 180, 194, 0.12);
      }

      .moment-item img {
        width: 100%;
        height: 220px;
        object-fit: cover;
        display: block;
      }

      .moment-content {
        padding: 1rem 1rem 1.2rem;
      }

      .moment-title {
        font-size: 1rem;
        letter-spacing: 0.12em;
        color: var(--title);
        margin: 0 0 0.4rem 0;
      }

      .moment-date {
        font-size: 0.84rem;
        color: #a98a95;
        margin-bottom: 0.6rem;
      }

      .moment-description {
        font-size: 0.94rem;
        line-height: 1.8;
        margin: 0;
      }

      @media (max-width: 900px) {
        .moments-grid {
          grid-template-columns: 1fr;
        }

        .hero-card,
        .about-card,
        .moments-card {
          padding: 1.5rem;
        }
      }
    </style>
  </head>

  <body>
    <div class="page-shell">
      <Header />
      <main class="main">
        <section class="hero-card">
          <h1 class="hero-title">XINYUAN</h1>
          <div class="hero-subtitle">
            A personal space for work, study, thoughts, and daily life.
          </div>
        </section>

        <section class="about-card">
          <h2 class="section-title">ABOUT ME</h2>
          <div class="about-text">
            <p>Hi, I’m Xinyuan.</p>
            <p>
              I’m currently living in Tokyo and working in network engineering in Japan.
            </p>
            <p>
              This website is my personal space to record work, study, thoughts,
              and everyday moments.
            </p>
            <p>
              Here, I write about technology, life, growth, and the small things
              that make ordinary days meaningful.
            </p>
          </div>
          <div class="about-link-wrap">
            <a class="about-link" href="/about">READ MORE</a>
          </div>
        </section>

        <section class="moments-card">
          <h2 class="section-title">MOMENTS</h2>
          <div class="moments-grid">
            {moments.map((moment) => (
              <article class="moment-item">
                <img src={moment.image} alt={moment.title} />
                <div class="moment-content">
                  <h3 class="moment-title">{moment.title}</h3>
                  <div class="moment-date">{moment.date}</div>
                  <p class="moment-description">{moment.description}</p>
                </div>
              </article>
            ))}
          </div>
        </section>
      </main>
      <Footer />
    </div>
  </body>
</html>