---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const moments = [
  {
    image: '/images/moments/takao.jpg',
    title: 'Takaozan',
    date: '2026.02',
    description: 'A quiet winter walk.',
  },
  {
    image: '/images/moments/birthday.jpg',
    title: 'Happy Birthday',
    date: '2026.03',
    description: 'A new chapter.',
  },
  {
    image: '/images/moments/takaoo.jpg',
    title: 'Facing the Light',
    date: '2026.01',
    description: 'Small moments, soft memories.',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      :root {
        --bg: #fcf7fa;
        --card: rgba(255, 255, 255, 0.72);
        --card-soft: rgba(250, 243, 247, 0.88);
        --border: rgba(232, 206, 218, 0.7);
        --text: #8c7881;
        --heading: #7c626d;
        --soft-heading: #b596a3;
        --link: #b98ea0;
        --link-hover: #c999ab;
        --shadow: 0 10px 30px rgba(214, 191, 202, 0.16);
      }

      html,
      body {
        margin: 0;
        padding: 0;
        background: linear-gradient(180deg, #fdf9fb 0%, #fbf5f8 100%);
        color: var(--text);
        font-family: "Times New Roman", Georgia, serif;
      }

      .page-shell {
        min-height: 100vh;
      }

      .main {
        width: min(1320px, 92%);
        margin: 0 auto;
        padding: 1.2rem 0 4rem;
      }

      .hero-card,
      .about-card,
      .moments-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 40px;
        box-shadow: var(--shadow);
      }

      .hero-card {
        padding: 3.2rem 2rem 3rem;
        text-align: center;
        margin-top: 1.4rem;
      }

      .hero-title {
        margin: 0;
        font-size: clamp(2.3rem, 5vw, 4rem);
        font-weight: 600;
        letter-spacing: 0.14em;
        color: var(--soft-heading);
        font-family: "Times New Roman", Georgia, serif;
      }

      .hero-subtitle {
        margin-top: 0.95rem;
        font-size: 1rem;
        line-height: 1.9;
        color: var(--text);
        font-family: "Times New Roman", Georgia, serif;
      }

      .about-card {
        margin-top: 2rem;
        padding: 3rem 3.2rem 2.7rem;
      }

      .section-title {
        margin: 0 0 1.4rem;
        font-size: clamp(2rem, 4.5vw, 3rem);
        font-weight: 700;
        letter-spacing: 0.01em;
        color: var(--heading);
        font-family: "Times New Roman", Georgia, serif;
      }

      .about-text {
        max-width: 1080px;
        font-size: 1rem;
        line-height: 2;
        color: var(--text);
        font-family: "Times New Roman", Georgia, serif;
      }

      .about-text p {
        margin: 0 0 1.2rem;
      }

      .about-link-wrap {
        margin-top: 1.2rem;
      }

      .about-link {
        display: inline-block;
        text-decoration: none;
        color: var(--link);
        font-size: 0.94rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        border-bottom: 1px solid rgba(185, 142, 160, 0.4);
        padding-bottom: 0.18rem;
        transition: color 0.2s ease, opacity 0.2s ease, border-color 0.2s ease;
        font-family: "Times New Roman", Georgia, serif;
      }

      .about-link:hover {
        color: var(--link-hover);
        border-bottom-color: rgba(201, 153, 171, 0.55);
        opacity: 0.9;
      }

      .about-grid {
        margin-top: 1.8rem;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.2rem;
      }

      .about-item {
        background: var(--card-soft);
        border-radius: 28px;
        padding: 1.35rem 1.45rem;
      }

      .about-item h3 {
        margin: 0 0 0.7rem;
        font-size: 1rem;
        font-weight: 700;
        color: var(--heading);
        font-family: "Times New Roman", Georgia, serif;
        letter-spacing: 0.02em;
      }

      .about-item p {
        margin: 0;
        font-size: 0.96rem;
        line-height: 1.8;
        color: var(--text);
        font-family: "Times New Roman", Georgia, serif;
      }

      .moments-card {
        margin-top: 2rem;
        padding: 2.4rem;
      }

      .moments-title {
        margin: 0 0 1.8rem;
        font-size: 1.08rem;
        letter-spacing: 0.18em;
        color: var(--soft-heading);
        font-weight: 600;
        font-family: "Times New Roman", Georgia, serif;
      }

      .moments-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1.4rem;
        align-items: stretch;
      }

      .moment-item {
        overflow: hidden;
        border-radius: 34px;
        background: rgba(255, 255, 255, 0.74);
        border: 1px solid rgba(232, 206, 218, 0.55);
        display: flex;
        flex-direction: column;
      }

      .moment-item img {
        width: 100%;
        height: 430px;
        object-fit: cover;
        display: block;
      }

      .moment-content {
        padding: 1.1rem 1.2rem 1.4rem;
      }

      .moment-content h3 {
        margin: 0 0 0.45rem;
        font-size: 1rem;
        letter-spacing: 0.04em;
        color: var(--heading);
        font-weight: 600;
        font-family: "Times New Roman", Georgia, serif;
      }

      .moment-date {
        font-size: 0.82rem;
        color: #ab97a0;
        margin-bottom: 0.8rem;
        font-family: "Times New Roman", Georgia, serif;
      }

      .moment-content p {
        margin: 0;
        font-size: 0.95rem;
        line-height: 1.7;
        color: #8c7881;
        font-family: "Times New Roman", Georgia, serif;
      }

      @media (max-width: 1100px) {
        .moments-grid {
          grid-template-columns: 1fr;
        }

        .moment-item img {
          height: 320px;
        }
      }

      @media (max-width: 900px) {
        .main {
          width: min(94%, 94%);
        }

        .hero-card,
        .about-card,
        .moments-card {
          border-radius: 28px;
        }

        .about-card,
        .moments-card {
          padding: 2rem 1.5rem;
        }

        .about-grid {
          grid-template-columns: 1fr;
        }

        .hero-title {
          font-size: clamp(2rem, 9vw, 3rem);
        }
      }
    </style>
  </head>

  <body>
    <div class="page-shell">
      <Header />

      <main class="main">
        <section class="hero-card">
          <h1 class="hero-title">XINYUAN</h1>
          <p class="hero-subtitle">
            A personal space for work, study, thoughts, and everyday life.
          </p>
        </section>

        <section class="about-card">
          <h2 class="section-title">About Me</h2>

          <div class="about-text">
            <p>Hi, I’m Xinyuan.</p>
            <p>
              I’m a network engineer based in Japan, and this blog is where I collect
              small traces of work, study, language, and everyday life.
            </p>
            <p>
              I like writing about things while they are still unfolding — not only
              the results, but also the confusion, the progress, and the process of
              understanding them.
            </p>
          </div>

          <div class="about-link-wrap">
            <a class="about-link" href="/about">Read More</a>
          </div>

          <div class="about-grid">
            <div class="about-item">
              <h3>💼 Work</h3>
              <p>
                Networking, troubleshooting, project notes, and weekly work logs.
              </p>
            </div>

            <div class="about-item">
              <h3>📚 Learning</h3>
              <p>
                Japanese study, technical growth, and things I want to understand more deeply.
              </p>
            </div>

            <div class="about-item">
              <h3>✍️ Writing</h3>
              <p>
                Personal reflections, small observations, and records of change over time.
              </p>
            </div>

            <div class="about-item">
              <h3>🌿 Life</h3>
              <p>
                Living in Japan, ordinary moments, and the quiet parts of daily life.
              </p>
            </div>
          </div>
        </section>

        <section class="moments-card">
          <h2 class="moments-title">MOMENTS</h2>

          <div class="moments-grid">
            {moments.map((moment) => (
              <article class="moment-item">
                <img src={moment.image} alt={moment.title} />
                <div class="moment-content">
                  <h3>{moment.title}</h3>
                  <div class="moment-date">{moment.date}</div>
                  <p>{moment.description}</p>
                </div>
              </article>
            ))}
          </div>
        </section>
      </main>

      <Footer />
    </div>
  </body>
</html>