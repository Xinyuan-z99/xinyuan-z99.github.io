---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI',
          sans-serif;
        background: linear-gradient(180deg, #fff9fc 0%, #fdeff6 100%);
        color: rgb(var(--black));
      }

      main {
        width: 1100px;
        max-width: calc(100% - 2rem);
        margin: 2.5rem auto 4rem;
      }

      .hero-card {
        background: rgba(255, 255, 255, 0.92);
        border-radius: 2rem;
        padding: 2.5rem 2.5rem 2.8rem;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
      }

      .hero-title {
        margin: 0 0 1.2rem;
        font-size: 3.2rem;
        line-height: 1.15;
        font-weight: 800;
        letter-spacing: -0.02em;
      }

      .hero-text {
        margin: 0;
        font-size: 1.15rem;
        line-height: 2;
        color: rgb(var(--gray));
        max-width: 920px;
      }

      .hero-text + .hero-text {
        margin-top: 1.4rem;
      }

      .bottom-space {
        height: 220px;
      }

      @media (max-width: 900px) {
        main {
          max-width: calc(100% - 1.25rem);
          margin: 1.5rem auto 3rem;
        }

        .hero-card {
          padding: 1.6rem 1.4rem 1.8rem;
          border-radius: 1.5rem;
        }

        .hero-title {
          font-size: 2.2rem;
          line-height: 1.2;
        }

        .hero-text {
          font-size: 1rem;
          line-height: 1.9;
        }

        .bottom-space {
          height: 120px;
        }
      }
    </style>
  </head>

  <body>
    <Header />

    <main>
      <section class="hero-card">
        <h1 class="hero-title">👩‍💻 Hi, this is Xinyuan’s blog</h1>

        <p class="hero-text">Hi, I’m Xinyuan.</p>

        <p class="hero-text">
          A small, quiet space for notes and observations.
        </p>

        <p class="hero-text">
          Here I document what I’m working on, what I’m learning, and how things
          slowly take shape over time.
        </p>

        <p class="hero-text">
          Topics include networking, Japanese, work logs, and daily reflections —
          not as finished answers, but as things in progress.
        </p>
      </section>

      <div class="bottom-space"></div>
    </main>

    <Footer />
  </body>
</html>