---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
  .filter(({ data }) => !data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI',
          sans-serif;
        background: linear-gradient(180deg, #fbfaff 0%, #fdfcff 55%, #ffffff 100%);
        background-attachment: fixed;
      }

      main {
        width: 960px;
        max-width: calc(100% - 2em);
        margin: 3rem auto 4rem;
        padding: 0 1.5rem;
      }

      .hero {
        margin-bottom: 3rem;
      }

      .hero-title {
        margin: 0 0 1rem;
        font-size: 3.2rem;
        line-height: 1.1;
        color: rgb(var(--black));
      }

      .hero-desc {
        margin: 0;
        font-size: 1.15rem;
        line-height: 1.8;
        color: rgb(var(--gray));
        max-width: 720px;
      }

      .section-title {
        margin: 0 0 1.2rem;
        font-size: 1.4rem;
        color: rgb(var(--black));
      }

      .post-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
      }

      .post-item a {
        display: block;
        text-decoration: none;
      }

      .post-title {
        margin: 0 0 0.3rem;
        font-size: 1.1rem;
        font-weight: 700;
        color: rgb(var(--black));
        line-height: 1.35;
      }

      .post-date {
        margin: 0;
        color: rgb(var(--gray));
        font-size: 0.95rem;
      }

      .post-item a:hover .post-title,
      .post-item a:hover .post-date {
        color: rgb(var(--accent));
      }

      .more-link {
        display: inline-block;
        margin-top: 1.5rem;
        font-size: 1rem;
        font-weight: 600;
        color: rgb(var(--accent));
        text-decoration: none;
      }

      .more-link:hover {
        text-decoration: underline;
      }

      @media (max-width: 720px) {
        main {
          margin: 2rem auto 3rem;
        }

        .hero-title {
          font-size: 2.4rem;
        }

        .hero-desc {
          font-size: 1rem;
        }
      }
    </style>
  </head>

  <body>
    <Header />
    <main>
      <section class="hero">
        <h1 class="hero-title">Welcome to {SITE_TITLE}</h1>
        <p class="hero-desc">{SITE_DESCRIPTION}</p>
      </section>

      <section>
        <h2 class="section-title">Latest Posts</h2>
        <ul class="post-list">
          {
            posts.map((post) => (
              <li class="post-item">
                <a href={`/blog/${post.id}/`}>
                  <p class="post-title">{post.data.title}</p>
                  <p class="post-date">
                    <FormattedDate date={post.data.pubDate} />
                  </p>
                </a>
              </li>
            ))
          }
        </ul>

        <a class="more-link" href="/blog/">View all posts →</a>
      </section>
    </main>
    <Footer />
  </body>
</html>
