---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const photos = [
  {
    image: '/images/gallery/mountain-01.JPG',
    title: 'Mountain',
    date: '2026.04',
  },
  {
    image: '/images/gallery/mountain-02.JPG',
    title: 'Forest',
    date: '2026.04',
  },
  {
    image: '/images/gallery/mountain-03.JPG',
    title: 'Sky',
    date: '2026.04',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Gallery | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>

  <body>
    <Header />

    <main class="gallery-page">
      <section class="hero">
        <p class="eyebrow">PHOTO ALBUM</p>
        <h1>Gallery</h1>
        <p class="intro">
          Small pieces of my life, collected quietly.
        </p>
      </section>

      <section class="photo-grid">
        {photos.map((photo) => (
          <article class="photo-card">
            <img src={photo.image} alt={photo.title} />
            <div class="photo-info">
              <h2>{photo.title}</h2>
              <p>{photo.date}</p>
            </div>
          </article>
        ))}
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  body {
    margin: 0;
    min-height: 100vh;
    background: linear-gradient(180deg, #ffe6f1 0%, #fff1f6 45%, #ffffff 100%);
    color: #6f5964;
  }

  .gallery-page {
    max-width: 1080px;
    margin: 0 auto;
    padding: 3rem 1.3rem 5rem;
  }

  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }

  .eyebrow {
    margin: 0 0 0.8rem;
    font-family: "Times New Roman", Georgia, serif;
    font-size: 0.85rem;
    letter-spacing: 0.28em;
    color: #c493a7;
  }

  h1 {
    margin: 0;
    font-family: "Times New Roman", Georgia, serif;
    font-size: clamp(3rem, 8vw, 5.8rem);
    font-weight: 500;
    letter-spacing: 0.08em;
    color: #8f7480;
  }

  .intro {
    margin: 1rem auto 0;
    max-width: 520px;
    font-size: 1rem;
    line-height: 1.9;
    color: #9a7b89;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.6rem;
  }

  .photo-card {
    overflow: hidden;
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(231, 196, 214, 0.55);
    box-shadow: 0 18px 42px rgba(210, 174, 193, 0.18);
  }

  .photo-card img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  .photo-info {
    padding: 1rem 1.1rem 1.2rem;
  }

  .photo-info h2 {
    margin: 0 0 0.35rem;
    font-family: "Times New Roman", Georgia, serif;
    font-size: 1.25rem;
    font-weight: 500;
    color: #8f7480;
  }

  .photo-info p {
    margin: 0;
    font-size: 0.9rem;
    color: #b58ca2;
  }

  @media (max-width: 850px) {
    .photo-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.1rem;
    }
  }

  @media (max-width: 560px) {
    .gallery-page {
      padding-top: 2rem;
    }

    .photo-grid {
      grid-template-columns: 1fr;
    }
  }
</style>