---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`About | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <style>
      :root {
        --bg1: #fff8fb;
        --bg2: #fdeff5;
        --card: rgba(255, 255, 255, 0.74);
        --border: rgba(255, 182, 193, 0.28);
        --text: #5b4b52;
        --title: #9f6f7d;
        --shadow: 0 10px 30px rgba(222, 170, 190, 0.16);
      }

      body {
        margin: 0;
        font-family: 'Times New Roman', serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(255, 255, 255, 0.95), transparent 35%),
          linear-gradient(135deg, var(--bg1), var(--bg2));
      }

      .page-shell {
        min-height: 100vh;
      }

      .main {
        width: min(900px, 92%);
        margin: 0 auto;
        padding: 2rem 0 4rem;
      }

      .about-card {
        margin-top: 1.5rem;
        background: var(--card);
        backdrop-filter: blur(10px);
        border: 1px solid var(--border);
        border-radius: 28px;
        box-shadow: var(--shadow);
        padding: 3rem 2rem;
      }

      .page-title {
        text-align: center;
        margin: 0 0 2rem 0;
        font-size: clamp(2rem, 4vw, 3.2rem);
        letter-spacing: 0.18em;
        color: var(--title);
        font-weight: 600;
      }

      .about-content {
        max-width: 720px;
        margin: 0 auto;
        font-size: 1.04rem;
        line-height: 2.05;
      }

      .about-content p {
        margin: 0 0 1.2rem 0;
      }

      @media (max-width: 768px) {
        .about-card {
          padding: 2rem 1.3rem;
        }
      }
    </style>
  </head>

  <body>
    <div class="page-shell">
      <Header />
      <main class="main">
        <section class="about-card">
          <h1 class="page-title">ABOUT</h1>
          <div class="about-content">
            <p>Hi, I’m Xinyuan.</p>

            <p>
              I’m currently living in Tokyo and working in network engineering in Japan.
              My daily life is closely connected to technology, problem-solving,
              learning, and continuous improvement.
            </p>

            <p>
              I created this website as a personal space to document my journey —
              not only in work and study, but also in life itself.
              Here, I share technical notes, work logs, reflections, and small
              everyday moments that I want to remember.
            </p>

            <p>
              For me, writing is a way to organize thoughts, preserve feelings,
              and look back on growth.
              Sometimes this site is a notebook for learning.
              Sometimes it is a quiet corner for recording life.
              Sometimes it is simply a place to leave traces of who I am at this moment.
            </p>

            <p>
              Beyond work, I also enjoy observing daily life, taking photos,
              writing personal reflections, and collecting meaningful memories.
              I hope this website can become a gentle archive of my time,
              growth, and experiences.
            </p>

            <p>Thank you for visiting.</p>
          </div>
        </section>
      </main>
      <Footer />
    </div>
  </body>
</html>