---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`About | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <style>
      :root {
        --bg: #fcf7fa;
        --card: rgba(255, 255, 255, 0.72);
        --card-soft: rgba(250, 243, 247, 0.9);
        --border: rgba(232, 206, 218, 0.7);
        --text: #8c7881;
        --heading: #7c626d;
        --soft-heading: #b596a3;
        --shadow: 0 10px 30px rgba(214, 191, 202, 0.16);
      }

html,
body {
  margin: 0;
  padding: 0;
  background: linear-gradient(180deg, #fdf9fb 0%, #fbf5f8 100%);
  color: var(--text);
}
      .page-shell {
        min-height: 100vh;
      }

      .main {
        width: min(1200px, 92%);
        margin: 0 auto;
        padding: 1.2rem 0 4rem;
      }

      .about-card {
        margin-top: 1.4rem;
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 40px;
        box-shadow: var(--shadow);
        padding: 3rem 3.2rem;
      }

      .eyebrow {
        margin: 0 0 0.6rem;
        font-size: 0.9rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--soft-heading);
        font-weight: 600;
        font-family: "Times New Roman", Georgia, serif;
      }

      .page-title {
        margin: 0 0 1.6rem;
        font-size: clamp(2.2rem, 5vw, 3.6rem);
        line-height: 1.08;
        letter-spacing: 0.02em;
        color: var(--heading);
        font-weight: 700;
        font-family: "Times New Roman", Georgia, serif;
      }

      .intro {
        max-width: 920px;
        font-size: 1.05rem;
        line-height: 2;
        color: var(--text);
        font-family: "Times New Roman", Georgia, serif;
      }

      .intro p {
        margin: 0 0 1.25rem;
      }

      .section-divider {
        height: 1px;
        background: rgba(232, 206, 218, 0.8);
        margin: 2rem 0;
      }

      .info-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.2rem;
      }

      .info-card {
        background: var(--card-soft);
        border-radius: 28px;
        padding: 1.4rem 1.5rem;
      }

      .info-card h2 {
        margin: 0 0 0.75rem;
        font-size: 1.08rem;
        color: var(--heading);
        font-weight: 700;
        letter-spacing: 0.03em;
        font-family: "Times New Roman", Georgia, serif;
      }

      .info-card p {
        margin: 0;
        font-size: 0.98rem;
        line-height: 1.9;
        color: var(--text);
        font-family: "Times New Roman", Georgia, serif;
      }

      .closing {
        margin-top: 2rem;
        font-size: 1rem;
        line-height: 1.95;
        color: var(--text);
        font-family: "Times New Roman", Georgia, serif;
      }

      .closing p {
        margin: 0;
      }

      @media (max-width: 900px) {
        .main {
          width: min(94%, 94%);
        }

        .about-card {
          border-radius: 28px;
          padding: 2rem 1.5rem;
        }

        .info-grid {
          grid-template-columns: 1fr;
        }

        .page-title {
          font-size: clamp(1.9rem, 8vw, 2.8rem);
        }

        .intro,
        .info-card p,
        .closing {
          font-size: 0.98rem;
        }
      }
    </style>
  </head>

  <body>
    <div class="page-shell">
      <Header />

      <main class="main">
        <section class="about-card">
          <p class="eyebrow">About</p>
          <h1 class="page-title">A Little More About Me</h1>

          <div class="intro">
            <p>
              Hi, I’m Xinyuan.
            </p>
            <p>
              I’m currently living in Japan and working in network engineering.
              My daily life is closely tied to technology, troubleshooting,
              project work, learning, and the slow process of becoming better at what I do.
            </p>
            <p>
              I made this website as a small place to keep traces of that journey.
              Not only the polished parts, but also the unfinished ones —
              the questions, the changes, the uncertainty, and the progress that
              often feels too small to notice in the moment.
            </p>
            <p>
              I like recording things while they are still in motion.
              Sometimes that means technical notes.
              Sometimes it becomes a weekly reflection, a language-learning memo,
              or a piece of writing about ordinary life in Japan.
            </p>
          </div>

          <div class="section-divider"></div>

          <div class="info-grid">
            <div class="info-card">
              <h2>💼 Work</h2>
              <p>
                I write about networking, troubleshooting, project progress,
                and the practical side of learning through work.
              </p>
            </div>

            <div class="info-card">
              <h2>📚 Learning</h2>
              <p>
                I’m also interested in language study, technical improvement,
                and documenting what I am still trying to understand.
              </p>
            </div>

            <div class="info-card">
              <h2>✍️ Writing</h2>
              <p>
                Writing helps me organize experience.
                It gives shape to things that might otherwise disappear into busy days.
              </p>
            </div>

            <div class="info-card">
              <h2>🌿 Life</h2>
              <p>
                Beyond work, I want this site to hold everyday moments too —
                small memories, thoughts, and the quiet texture of daily life.
              </p>
            </div>
          </div>

          <div class="closing">
            <p>
              This website is not meant to be perfect.
              I hope it can simply become an honest archive of work, growth,
              curiosity, and life as I am living it now.
            </p>
          </div>
        </section>
      </main>

      <Footer />
    </div>
  </body>
</html>