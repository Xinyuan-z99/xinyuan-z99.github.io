---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`About | ${SITE_TITLE}`} description="About Xinyuan" />
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        background: linear-gradient(180deg, #fff9fc 0%, #fdeff6 100%);
        color: rgb(var(--black));
      }

      main {
        width: 960px;
        max-width: calc(100% - 2rem);
        margin: 2.5rem auto 4rem;
      }

      .about-card {
        background: rgba(255, 255, 255, 0.92);
        border-radius: 2rem;
        padding: 2.5rem 2.5rem 2.8rem;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
      }

      .page-title {
        margin: 0 0 1.2rem;
        font-size: 2.4rem;
        line-height: 1.15;
        font-weight: 800;
        letter-spacing: -0.02em;
      }

      .about-text {
        margin: 0;
        font-size: 1.1rem;
        line-height: 2;
        color: rgb(var(--gray));
      }

      .about-text + .about-text {
        margin-top: 1.3rem;
      }

      .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.2rem;
        margin-top: 2rem;
      }

      .info-item {
        background: rgba(250, 244, 248, 0.72);
        border-radius: 1.2rem;
        padding: 1.2rem;
      }

      .info-title {
        margin: 0 0 0.5rem;
        font-size: 1rem;
        font-weight: 700;
        color: rgb(var(--black));
      }

      .info-text {
        margin: 0;
        font-size: 0.96rem;
        line-height: 1.8;
        color: rgb(var(--gray));
      }

      @media (max-width: 900px) {
        main {
          max-width: calc(100% - 1.25rem);
          margin: 1.5rem auto 3rem;
        }

        .about-card {
          padding: 1.6rem 1.4rem 1.8rem;
          border-radius: 1.5rem;
        }

        .page-title {
          font-size: 2rem;
        }

        .about-text {
          font-size: 1rem;
          line-height: 1.9;
        }

        .info-grid {
          grid-template-columns: 1fr;
          gap: 1rem;
        }
      }
    </style>
  </head>

  <body>
    <Header />

    <main>
      <section class="about-card">
        <h1 class="page-title">About Me</h1>

        <p class="about-text">Hi, I’m Xinyuan.</p>

        <p class="about-text">
          I’m a network engineer based in Japan, and this blog is a small space
          where I write about work, study, language, and everyday life.
        </p>

        <p class="about-text">
          I like documenting things while they are still unfolding — not only the
          results, but also the process, the confusion, and the small progress
          along the way.
        </p>

        <div class="info-grid">
          <div class="info-item">
            <h2 class="info-title">💼 Work</h2>
            <p class="info-text">
              Notes on networking, troubleshooting, project tasks, and weekly work logs.
            </p>
          </div>

          <div class="info-item">
            <h2 class="info-title">📚 Learning</h2>
            <p class="info-text">
              Japanese study, technical learning, and things I want to understand more deeply.
            </p>
          </div>

          <div class="info-item">
            <h2 class="info-title">✍️ Writing</h2>
            <p class="info-text">
              Personal reflections, daily notes, and thoughts captured in progress.
            </p>
          </div>

          <div class="info-item">
            <h2 class="info-title">🌿 Life</h2>
            <p class="info-text">
              Small observations from living in Japan and the quiet details of everyday life.
            </p>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>