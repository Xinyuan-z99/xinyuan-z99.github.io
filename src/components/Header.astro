---
const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="header-inner">
    <nav class="nav">
      <a href="/" class={currentPath === '/' ? 'active' : ''}>HOME</a>
      <a href="/blog" class={currentPath.startsWith('/blog') ? 'active' : ''}>BLOG</a>
      <a href="/about" class={currentPath.startsWith('/about') ? 'active' : ''}>ABOUT</a>
    </nav>

    <div class="tokyo-time" id="tokyo-time">Tokyo Time · --</div>
  </div>
</header>

<script>
  function updateTokyoTime() {
    const el = document.getElementById('tokyo-time');
    if (!el) return;

    const now = new Date();

    const dateFormatter = new Intl.DateTimeFormat('en-US', {
      timeZone: 'Asia/Tokyo',
      month: 'long',
      day: 'numeric',
      year: 'numeric',
      weekday: 'long',
    });

    const timeFormatter = new Intl.DateTimeFormat('en-US', {
      timeZone: 'Asia/Tokyo',
      hour: '2-digit',
      minute: '2-digit',
      hour12: false,
    });

    const parts = dateFormatter.formatToParts(now);

    const month = parts.find((p) => p.type === 'month')?.value ?? '';
    const day = parts.find((p) => p.type === 'day')?.value ?? '';
    const year = parts.find((p) => p.type === 'year')?.value ?? '';
    const weekday = parts.find((p) => p.type === 'weekday')?.value ?? '';
    const time = timeFormatter.format(now);

    el.textContent = `${month} ${day}, ${year} · ${weekday} · ${time}`;
  }

  updateTokyoTime();
  setInterval(updateTokyoTime, 60000);
</script>

<style>
  .site-header {
    width: 100%;
    padding: 2.2rem 1rem 1.2rem;
  }

  .header-inner {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
  }

  .nav {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 3rem;
  }

  .nav a {
    position: relative;
    text-decoration: none;
    font-family: "Times New Roman", Georgia, serif;
    font-size: 1.18rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    color: #8f7480;
    transition: color 0.25s ease, transform 0.2s ease, opacity 0.2s ease;
  }

  .nav a:hover {
    color: #c493a7;
    transform: translateY(-1px);
    opacity: 0.95;
  }

  .nav a.active {
    color: #d49ab6;
  }

  .nav a.active::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: -0.42rem;
    transform: translateX(-50%);
    width: 68%;
    height: 1px;
    background: rgba(212, 154, 182, 0.75);
    border-radius: 999px;
  }

  .tokyo-time {
    position: absolute;
    top: 50%;
    right: 0;
    transform: translateY(-50%);
    font-family: "Times New Roman", Georgia, serif;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: #b58ca2;
    background: rgba(252, 243, 248, 0.88);
    border: 1px solid rgba(231, 196, 214, 0.55);
    padding: 0.54rem 0.92rem;
    border-radius: 999px;
    white-space: nowrap;
    box-shadow: 0 6px 18px rgba(220, 188, 205, 0.1);
    backdrop-filter: blur(6px);
  }

  @media (max-width: 900px) {
    .site-header {
      padding: 1.6rem 1rem 0.9rem;
    }

    .header-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.9rem;
    }

    .nav {
      gap: 1.4rem;
    }

    .nav a {
      font-size: 1rem;
      letter-spacing: 0.14em;
    }

    .tokyo-time {
      position: static;
      transform: none;
      font-size: 0.84rem;
      padding: 0.44rem 0.78rem;
    }
  }
</style>